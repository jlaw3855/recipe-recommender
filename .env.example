# Data mode: bundled (offline, 0 API calls) | live (Spoonacular) | auto (live if key set, else bundled)
DATA_MODE=bundled

# Required for live/auto mode — get a free key at https://spoonacular.com/food-api
SPOONACULAR_API_KEY=your_api_key_here

# Daily Spoonacular call limit (tracked in-memory per server session)
DAILY_API_QUOTA=50
